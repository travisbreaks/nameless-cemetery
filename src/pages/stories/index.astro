---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection } from 'astro:content'

const stories = (await getCollection('stories')).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime()
)
---

<BaseLayout
  title="Stories"
  description="Stories, family histories, and community news from Nameless Cemetery in Travis County, Texas."
>
  <section class="page-header">
    <div class="container--narrow">
      <h1>Stories</h1>
      <p class="page-intro">
        Family histories, community news, and memories from the Nameless Cemetery community.
      </p>
    </div>
  </section>

  <section class="section">
    <div class="container--narrow">
      <div class="stories-list">
        {stories.map((story) => (
          <article class="story-card" data-reveal>
            {story.data.images?.[0] && (
              <a href={`/stories/${story.slug}/`} class="story-card-image">
                <img
                  src={story.data.images[0].src}
                  alt={story.data.images[0].alt}
                  loading="lazy"
                />
              </a>
            )}
            <div class="story-card-body">
              <span class="story-category">{story.data.category}</span>
              <h2 class="story-card-title">
                <a href={`/stories/${story.slug}/`}>{story.data.title}</a>
              </h2>
              <time class="story-date" datetime={story.data.date.toISOString()}>
                {story.data.date.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long',
                  day: 'numeric',
                })}
              </time>
              {story.data.description && (
                <p class="story-excerpt">{story.data.description}</p>
              )}
              <a href={`/stories/${story.slug}/`} class="story-read-more">Read more</a>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .page-header {
    padding-top: var(--space-3xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--sandstone);
  }

  .page-header h1 {
    margin-bottom: var(--space-md);
  }

  .page-intro {
    font-size: var(--text-lg);
    color: var(--patina);
    line-height: 1.7;
  }

  .section {
    padding-top: var(--space-2xl);
  }

  .stories-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-2xl);
  }

  .story-card {
    display: grid;
    grid-template-columns: 240px 1fr;
    gap: var(--space-xl);
    align-items: start;
    padding-bottom: var(--space-2xl);
    border-bottom: 1px solid var(--sandstone);
  }

  .story-card:last-child {
    border-bottom: none;
  }

  .story-card-image {
    border-radius: 6px;
    overflow: hidden;
    display: block;
  }

  .story-card-image img {
    width: 100%;
    height: 180px;
    object-fit: cover;
    transition: transform 0.4s var(--ease);
  }

  .story-card-image:hover img {
    transform: scale(1.03);
  }

  .story-card-body {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .story-category {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--rust);
  }

  .story-card-title {
    font-size: var(--text-xl);
    margin: 0;
  }

  .story-card-title a {
    color: var(--iron);
    text-decoration: none;
  }

  .story-card-title a:hover {
    color: var(--live-oak);
  }

  .story-date {
    font-size: var(--text-sm);
    color: var(--patina);
  }

  .story-excerpt {
    font-size: var(--text-base);
    color: var(--patina);
    margin: var(--space-xs) 0 0 0;
    line-height: 1.6;
  }

  .story-read-more {
    font-size: var(--text-sm);
    font-weight: 600;
    margin-top: var(--space-sm);
    text-decoration: none;
    color: var(--live-oak);
  }

  .story-read-more:hover {
    color: var(--sky);
  }

  /* Cards without images go full-width */
  .story-card:not(:has(.story-card-image)) {
    grid-template-columns: 1fr;
  }

  @media (max-width: 640px) {
    .story-card {
      grid-template-columns: 1fr;
      gap: var(--space-md);
    }

    .story-card-image img {
      height: 200px;
    }
  }
</style>
