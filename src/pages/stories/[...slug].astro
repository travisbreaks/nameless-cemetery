---
import BaseLayout from '../../layouts/BaseLayout.astro'
import { getCollection, render } from 'astro:content'

export async function getStaticPaths() {
  const stories = await getCollection('stories')
  return stories.map((story) => ({
    params: { slug: story.slug },
    props: { story },
  }))
}

const { story } = Astro.props
const { Content } = await render(story)
const { title, date, author, category, description, images, comments, originalUrl } = story.data

const formattedDate = date.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<BaseLayout
  title={title}
  description={description || `${title} - a story from the Nameless Cemetery community.`}
  ogType="article"
  publishedDate={date}
  author={author}
>
  <article class="story-article">
    <header class="story-header">
      <div class="container--narrow">
        <a href="/stories/" class="back-link">&larr; All Stories</a>
        <span class="story-category">{category}</span>
        <h1>{title}</h1>
        <div class="story-meta">
          <time datetime={date.toISOString()}>{formattedDate}</time>
          <span class="meta-sep">&middot;</span>
          <span>{author}</span>
        </div>
      </div>
    </header>

    {images && images.length > 0 && (
      <section class="story-images">
        <div class="container--narrow">
          {images.length === 1 ? (
            <figure class="story-figure story-figure--single" data-reveal>
              <img src={images[0].src} alt={images[0].alt} loading="lazy" />
              {images[0].caption && <figcaption>{images[0].caption}</figcaption>}
            </figure>
          ) : (
            <div class="gallery" data-reveal>
              <div class="gallery-featured">
                <span class="gallery-counter" id="gallery-counter">1 / {images.length}</span>
                <div class="gallery-image-wrap">
                  <div
                    class="gallery-backdrop"
                    id="gallery-backdrop"
                    style={`background-image: url("${images[0].src}")`}
                  />
                  <img
                    id="gallery-main"
                    src={images[0].src}
                    alt={images[0].alt}
                    loading="eager"
                  />
                </div>
                <p class="gallery-caption" id="gallery-caption">{images[0].caption || ''}</p>
              </div>
              <div class="gallery-thumbs">
                {images.map((img, i) => (
                  <button
                    class={`gallery-thumb ${i === 0 ? 'gallery-thumb--active' : ''}`}
                    data-index={i}
                    data-src={img.src}
                    data-alt={img.alt}
                    data-caption={img.caption || ''}
                    type="button"
                    aria-label={`View photo: ${img.caption || img.alt}`}
                  >
                    <img src={img.src} alt={img.alt} loading="lazy" />
                  </button>
                ))}
              </div>
            </div>
          )}
        </div>
      </section>
    )}

    <section class="story-body">
      <div class="container--narrow">
        <div class="prose">
          <Content />
        </div>
      </div>
    </section>

    {comments && comments.length > 0 && (
      <section class="story-comments">
        <div class="container--narrow">
          <h2>Community Responses</h2>
          <p class="comments-note">
            These comments were left on the original blog post and preserved here.
          </p>
          <div class="comments-list">
            {comments.map((comment) => (
              <div class:list={['comment', { 'comment--reply': comment.isReply }]}>
                <div class="comment-header">
                  <strong class="comment-name">{comment.name}</strong>
                  <span class="comment-date">{comment.date}</span>
                </div>
                <p class="comment-text" set:html={comment.text} />
              </div>
            ))}
          </div>
        </div>
      </section>
    )}

    {originalUrl && (
      <footer class="story-footer">
        <div class="container--narrow">
          <p class="original-source">
            Originally published on the
            <a href={originalUrl} target="_blank" rel="noopener noreferrer">Nameless Cemetery WordPress blog</a>.
          </p>
        </div>
      </footer>
    )}
  </article>
</BaseLayout>

<style>
  .story-header {
    padding-top: var(--space-2xl);
    padding-bottom: var(--space-xl);
    border-bottom: 1px solid var(--sandstone);
  }

  .back-link {
    display: inline-block;
    font-size: var(--text-sm);
    color: var(--patina);
    text-decoration: none;
    margin-bottom: var(--space-lg);
    transition: color var(--duration) var(--ease);
  }

  .back-link:hover {
    color: var(--live-oak);
  }

  .story-category {
    display: inline-block;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--rust);
    margin-bottom: var(--space-sm);
  }

  .story-header h1 {
    margin-bottom: var(--space-sm);
  }

  .story-meta {
    font-size: var(--text-sm);
    color: var(--patina);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
  }

  .meta-sep {
    color: var(--sandstone);
  }

  /* Images */
  .story-images {
    padding-top: var(--space-2xl);
  }

  .story-figure--single {
    border-radius: 6px;
    overflow: hidden;
  }

  .story-figure--single img {
    width: 100%;
    height: auto;
  }

  .story-figure--single figcaption {
    font-size: var(--text-sm);
    color: var(--patina);
    font-style: italic;
    padding-top: var(--space-sm);
    text-align: center;
  }

  .gallery-caption {
    font-size: var(--text-base);
    color: var(--patina);
    font-style: italic;
    text-align: center;
    padding: var(--space-sm) var(--space-md);
    flex-shrink: 0;
  }

  /* Gallery */
  .gallery-featured {
    position: relative;
    border-radius: 6px;
    overflow: hidden;
    background: var(--color-bg-alt);
    height: 520px;
    display: flex;
    flex-direction: column;
  }

  .gallery-image-wrap {
    position: relative;
    flex: 1;
    min-height: 0;
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .gallery-backdrop {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    transform: scale(1.15);
    filter: blur(24px) brightness(0.8);
    z-index: 0;
  }

  .gallery-image-wrap img {
    position: relative;
    z-index: 1;
    max-width: 100%;
    max-height: 100%;
    object-fit: contain;
    display: block;
    box-shadow: 0 2px 16px rgba(0, 0, 0, 0.35);
    transition: opacity 0.25s cubic-bezier(0.45, 0, 0.55, 1);
  }

  .gallery-image-wrap img.gallery-fade {
    opacity: 0;
  }

  .gallery-counter {
    position: absolute;
    top: var(--space-sm);
    right: var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--white);
    background: rgba(0, 0, 0, 0.5);
    padding: 2px 8px;
    border-radius: 999px;
    z-index: 1;
  }

  .gallery-thumbs {
    display: flex;
    gap: var(--space-xs);
    margin-top: var(--space-sm);
    overflow-x: auto;
    padding-bottom: var(--space-xs);
    scrollbar-width: thin;
    scrollbar-color: var(--sandstone) transparent;
  }

  .gallery-thumbs::-webkit-scrollbar {
    height: 4px;
  }

  .gallery-thumbs::-webkit-scrollbar-thumb {
    background: var(--sandstone);
    border-radius: 2px;
  }

  .gallery-thumb {
    flex-shrink: 0;
    width: 72px;
    height: 72px;
    padding: 0;
    border: 2px solid transparent;
    border-radius: 4px;
    overflow: hidden;
    cursor: pointer;
    background: none;
    opacity: 0.6;
    transition: opacity 0.2s cubic-bezier(0.45, 0, 0.55, 1), border-color 0.2s cubic-bezier(0.45, 0, 0.55, 1);
  }

  .gallery-thumb:hover {
    opacity: 0.9;
  }

  .gallery-thumb--active {
    opacity: 1;
    border-color: var(--live-oak);
  }

  .gallery-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: top;
    display: block;
  }

  /* Body */
  .story-body {
    padding-top: var(--space-2xl);
  }

  .prose {
    font-size: var(--text-base);
    line-height: 1.8;
  }

  .prose :global(p) {
    margin-bottom: var(--space-lg);
  }

  /* Comments */
  .story-comments {
    padding-top: var(--space-3xl);
    margin-top: var(--space-2xl);
    border-top: 1px solid var(--sandstone);
  }

  .story-comments h2 {
    font-size: var(--text-2xl);
    margin-top: 0;
    margin-bottom: var(--space-sm);
  }

  .comments-note {
    font-size: var(--text-sm);
    color: var(--patina);
    font-style: italic;
    margin-bottom: var(--space-xl);
  }

  .comments-list {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .comment {
    background: var(--color-bg-alt);
    padding: var(--space-lg);
    border-radius: 6px;
    border-left: 3px solid var(--sandstone);
  }

  .comment--reply {
    margin-left: var(--space-xl);
    border-left-color: var(--live-oak);
    background: var(--white);
  }

  .comment-header {
    display: flex;
    align-items: baseline;
    gap: var(--space-md);
    margin-bottom: var(--space-sm);
  }

  .comment-name {
    font-size: var(--text-sm);
    color: var(--iron);
  }

  .comment-date {
    font-size: var(--text-xs);
    color: var(--patina);
  }

  .comment-text {
    font-size: var(--text-base);
    color: var(--patina);
    margin: 0;
    line-height: 1.6;
  }

  .comment--reply .comment-name {
    color: var(--live-oak);
  }

  /* Footer */
  .story-footer {
    margin-top: var(--space-2xl);
    padding-top: var(--space-lg);
    border-top: 1px solid var(--sandstone);
  }

  .original-source {
    font-size: var(--text-sm);
    color: var(--patina);
    font-style: italic;
  }

  @media (max-width: 640px) {
    .gallery-featured {
      height: 360px;
    }

    .gallery-thumb {
      width: 56px;
      height: 56px;
    }

    .comment--reply {
      margin-left: var(--space-md);
    }
  }
</style>

<script>
  const gallery = document.querySelector('.gallery')
  if (gallery) {
    const mainImg = document.getElementById('gallery-main') as HTMLImageElement
    const backdrop = document.getElementById('gallery-backdrop') as HTMLElement
    const caption = document.getElementById('gallery-caption') as HTMLElement
    const counter = document.getElementById('gallery-counter') as HTMLElement
    const thumbs = gallery.querySelectorAll<HTMLButtonElement>('.gallery-thumb')
    const total = thumbs.length

    thumbs.forEach((thumb) => {
      thumb.addEventListener('click', () => {
        const idx = parseInt(thumb.dataset.index || '0', 10)
        const src = thumb.dataset.src || ''
        const alt = thumb.dataset.alt || ''
        const cap = thumb.dataset.caption || ''

        // Fade out
        mainImg.classList.add('gallery-fade')

        setTimeout(() => {
          mainImg.src = src
          mainImg.alt = alt
          if (backdrop) backdrop.style.backgroundImage = `url("${src}")`
          caption.textContent = cap
          counter.textContent = `${idx + 1} / ${total}`

          // Fade in once loaded
          if (mainImg.complete) {
            mainImg.classList.remove('gallery-fade')
          } else {
            mainImg.onload = () => mainImg.classList.remove('gallery-fade')
          }
        }, 150)

        // Update active thumb
        thumbs.forEach((t) => t.classList.remove('gallery-thumb--active'))
        thumb.classList.add('gallery-thumb--active')

        // Scroll thumb into view
        thumb.scrollIntoView({ behavior: 'smooth', block: 'nearest', inline: 'center' })
      })
    })
  }
</script>
