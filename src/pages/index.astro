---
import BaseLayout from '../layouts/BaseLayout.astro'
---

<BaseLayout title="Home">
  <!-- Hero -->
  <section class="hero">
    <div class="hero-frame" data-reveal="scale">
      <img
        src="/images/gate-arch-hero-1920.jpg"
        srcset="/images/gate-arch-hero-768.jpg 768w, /images/gate-arch-hero-1920.jpg 1920w"
        sizes="(max-width: 768px) calc(100vw - 2rem), calc(100vw - 6rem)"
        alt="The iron gate arch of Nameless Cemetery with the cemetery name forged into the arch"
        class="hero-image"
        loading="eager"
      />
    </div>
    <div class="hero-bar">
      <div class="container hero-content" data-reveal>
        <p class="hero-subtitle">Est. 1882. Preserved by family and community.</p>
        <a
          href="https://maps.google.com/maps?q=30.524370,-97.928292&t=k&z=17"
          target="_blank"
          rel="noopener"
          class="hero-location"
        >
          23426 Nameless Road, Leander, Texas
        </a>
      </div>
    </div>
  </section>

  <!-- About -->
  <section class="section">
    <div class="container--narrow">
      <h2 data-reveal>About the Cemetery</h2>
      <figure class="photo-feature" data-reveal>
        <img src="/images/historical-marker.jpg" alt="Texas Historical Commission marker for the community of Nameless" loading="lazy" />
        <figcaption>The state historical marker at Nameless, erected 1970</figcaption>
      </figure>
      <p>
        Nameless Cemetery sits on land deeded to Travis County in 1906 by Bell and Rose Turner
        "for a public free school and burial grounds and church purposes." The earliest known
        burial dates to 1882, when two-year-old Rudolf Kauffman was laid to rest here.
      </p>
      <p>
        Today the cemetery holds approximately 169 burials spanning over 140 years of Hill Country
        families. The Nameless Cemetery Association was formed in 2009 to preserve, maintain, and
        honor this historic ground.
      </p>
      <p>
        In 2007, the cemetery received its
        <strong>Historic Texas Cemetery</strong> designation from the Texas Historical Commission.
      </p>
      <figure class="photo-feature" data-reveal>
        <img src="/images/bonnet-plot.jpeg" alt="The Bonnet family plot at Nameless Cemetery" loading="lazy" />
      </figure>
    </div>
  </section>

  <!-- Quick Facts -->
  <section class="section section--alt">
    <div class="container">
      <h2 class="text-center" data-reveal>By the Numbers</h2>
      <div class="facts-grid" data-reveal-stagger>
        <div class="fact-card">
          <span class="fact-number" data-count-to="1882">1882</span>
          <span class="fact-label">Earliest known burial</span>
        </div>
        <div class="fact-card">
          <span class="fact-number" data-count-to="169">169</span>
          <span class="fact-label">Burials recorded</span>
        </div>
        <div class="fact-card">
          <span class="fact-number" data-count-to="2007">2007</span>
          <span class="fact-label">Historic Texas Cemetery</span>
        </div>
        <div class="fact-card">
          <span class="fact-number" data-count-to="2009">2009</span>
          <span class="fact-label">Association formed</span>
        </div>
      </div>
    </div>
  </section>

  <!-- The Naming Legend -->
  <section class="section">
    <div class="container--narrow">
      <h2 data-reveal>Why "Nameless"?</h2>
      <p>
        When settlers applied for a post office in 1880, postal authorities rejected six proposed
        names. Frustrated, the citizens replied:
      </p>
      <blockquote data-reveal="slide-left">
        <span class="typewriter" data-typewriter="&quot;Let the post office be nameless and be d---d.&quot;">&nbsp;</span>
      </blockquote>
      <p>
        The postal department accepted it. The name stuck, and it is inscribed on the community's
        historical marker to this day.
      </p>
    </div>
  </section>

  <!-- Upcoming -->
  <section class="section section--alt">
    <div class="container--narrow">
      <h2 data-reveal>Upcoming Events</h2>
      <div class="event-card" data-reveal>
        <div class="event-date">
          <span class="event-month">MAR</span>
          <span class="event-day">30</span>
        </div>
        <div class="event-info">
          <h3>Historical Marker</h3>
          <p>The association is exploring a Texas Historical Commission marker for Nameless Cemetery.
          Stay tuned for updates.</p>
        </div>
      </div>
      <div class="event-card" data-reveal>
        <div class="event-date">
          <span class="event-month">APR</span>
          <span class="event-day">18</span>
        </div>
        <div class="event-info">
          <h3><a href="https://www.facebook.com/FriendsofNamelessSchool" target="_blank" rel="noopener">Return to Nameless</a></h3>
          <p>10:00 AM to 3:00 PM at the Nameless Schoolhouse. Hosted by
          <a href="https://www.facebook.com/FriendsofNamelessSchool" target="_blank" rel="noopener">Friends of Nameless School</a>.
          Silent auction, soapmaking, Texas Ranger display, bobbin lace making, local authors,
          music, pioneer artifacts, spinning and weaving, and more. Free event to benefit the
          Nameless School and the Gray House.</p>
          <a
            href="https://calendar.google.com/calendar/render?action=TEMPLATE&text=Return+to+Nameless&dates=20260418T150000Z/20260418T200000Z&details=Free+event+to+benefit+Nameless+School+and+the+Gray+House.+Silent+auction,+soapmaking,+Texas+Ranger+display,+music,+pioneer+artifacts,+and+more.+Hosted+by+Friends+of+Nameless+School.&location=Nameless+Schoolhouse,+23426+Nameless+Road,+Leander,+TX+78641"
            target="_blank"
            rel="noopener"
            class="add-to-cal"
          >+ Add to calendar</a>
        </div>
      </div>
      <div class="event-card" data-reveal>
        <div class="event-date">
          <span class="event-month">OCT</span>
          <span class="event-day">TBD</span>
        </div>
        <div class="event-info">
          <h3>Annual Meeting</h3>
          <p>First Saturday in October (date TBD). Yearly gathering at the Nameless Schoolhouse.
          <a href="mailto:info@namelesscemetery.org?subject=Mailing%20List">Sign up for our mailing list</a> for updates.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Find Us -->
  <section class="section">
    <div class="container--narrow">
      <h2 class="text-center" data-reveal>Find Us</h2>
      <div class="map-container" data-reveal>
        <iframe
          src="https://maps.google.com/maps?q=30.524370,-97.928292&t=k&z=17&output=embed"
          width="100%"
          height="400"
          style="border:0; border-radius: 6px;"
          allowfullscreen=""
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Map showing location of Nameless Cemetery"
        ></iframe>
      </div>
      <p class="map-address text-center">
        <a
          href="https://maps.google.com/maps?q=30.524370,-97.928292&t=k&z=17"
          target="_blank"
          rel="noopener"
        >
          23426 Nameless Road, Leander, TX 78641
        </a>
      </p>
    </div>
  </section>

  <!-- CTA -->
  <section class="section section--alt cta-section">
    <div class="container--narrow text-center">
      <h2 data-reveal>Help Us Preserve This <a href="/history/" class="cta-history-link">History</a></h2>
      <p>
        Whether your family is buried here, you live nearby, or you care about Texas history,
        there are ways to get involved.
      </p>
      <div class="cta-actions">
        <a href="/help/" class="btn btn--primary">Learn How to Help</a>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  /* Hero */
  .hero {
    background: #28261a;
    display: flex;
    flex-direction: column;
  }

  .hero-frame {
    position: relative;
    padding: var(--space-4xl) var(--space-3xl) var(--space-3xl);
    background: linear-gradient(
      to bottom,
      #2a3545 0%,
      #28261a 30%,
      #302a24 100%
    );
    display: flex;
    justify-content: center;
  }


  .hero-frame img {
    width: 100%;
    max-width: 1100px;
    height: auto;
    display: block;
    /* Inner fillet - dark graphite like the sign lettering */
    border: 2px solid #4a4a4a;
    /* Cream mat */
    outline: 24px solid #e8e0d0;
    /* Outer fillet */
    outline-offset: 0px;
    /* Museum frame layers - wrought iron black */
    box-shadow:
      /* inner bevel light */
      inset 0 0 0 1px rgba(255, 255, 255, 0.08),
      /* mat outer edge */
      0 0 0 26px #e8e0d0,
      /* dark iron inner frame */
      0 0 0 28px #3a3a3a,
      /* wrought iron frame */
      0 0 0 38px #1a1a1a,
      /* frame highlight (subtle top-left light) */
      0 0 0 39px #333333,
      /* outer frame edge */
      0 0 0 42px #111111,
      /* drop shadow */
      0 16px 48px rgba(0, 0, 0, 0.5);
  }

  .hero-bar {
    background: linear-gradient(
      to bottom,
      #302a24 0%,
      #2a2720 50%,
      #242a32 100%
    );
    padding-block: var(--space-lg);
  }

  .hero-content {
    max-width: var(--max-width);
    margin-inline: auto;
    padding-inline: var(--space-lg);
    text-align: center;
    color: var(--parchment);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-sm);
  }

  .hero-subtitle {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-weight: 400;
    font-style: italic;
    color: var(--sandstone);
    margin: 0;
  }

  .hero-location {
    font-size: var(--text-base);
    color: var(--parchment);
    opacity: 0.7;
    text-decoration: none;
    border-bottom: 1px solid rgba(237, 230, 216, 0.3);
    padding-bottom: 1px;
    transition: opacity var(--duration) var(--ease);
    margin: 0;
  }

  .hero-location:hover {
    opacity: 1;
    color: var(--parchment);
  }


  /* Sections */
  .section {
    padding-block: var(--space-3xl);
  }

  .section--alt {
    background: var(--color-bg-alt);
  }

  .text-center {
    text-align: center;
  }

  /* Facts grid */
  .facts-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: var(--space-lg);
    margin-top: var(--space-xl);
  }

  .fact-card {
    text-align: center;
    padding: var(--space-xl) var(--space-md);
    background: var(--white);
    border-radius: 6px;
    border: 1px solid var(--sandstone);
  }

  .fact-number {
    display: block;
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    color: var(--live-oak);
    margin-bottom: var(--space-xs);
  }

  .fact-label {
    font-size: var(--text-sm);
    color: var(--patina);
  }

  /* Blockquote */
  blockquote {
    font-family: var(--font-heading);
    font-size: var(--text-xl);
    font-style: italic;
    color: var(--patina);
    border-left: 4px solid var(--rust);
    padding-left: var(--space-lg);
    margin-block: var(--space-xl);
    min-height: 2.4em;
  }

  /* Typewriter */
  .typewriter {
    display: inline;
  }

  .typewriter::after {
    content: '|';
    display: inline;
    animation: blink 0.8s cubic-bezier(0.45, 0, 0.55, 1) infinite;
    color: var(--rust);
    font-style: normal;
    margin-left: 1px;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50% { opacity: 0; }
  }

  /* Events */
  .event-card {
    display: flex;
    gap: var(--space-lg);
    padding: var(--space-lg);
    background: var(--white);
    border-radius: 6px;
    border: 1px solid var(--sandstone);
    margin-bottom: var(--space-md);
  }

  .event-date {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    width: 72px;
    height: 72px;
    padding: var(--space-xs);
    background: var(--live-oak);
    color: var(--white);
    border-radius: 8px;
    text-align: center;
    flex-shrink: 0;
  }

  .event-month {
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
  }

  .event-day {
    font-family: var(--font-heading);
    font-size: var(--text-2xl);
    font-weight: 700;
    line-height: 1;
  }

  .event-info h3 {
    font-size: var(--text-lg);
    margin-top: 0;
    margin-bottom: var(--space-xs);
  }

  .add-to-cal {
    display: inline-block;
    margin-top: var(--space-sm);
    font-size: var(--text-xs);
    font-weight: 600;
    color: var(--live-oak);
    text-decoration: none;
    border: 1px solid var(--live-oak);
    border-radius: 999px;
    padding: 0.25rem 0.75rem;
    transition: background var(--duration) var(--ease), color var(--duration) var(--ease);
  }

  .add-to-cal:hover {
    background: var(--live-oak);
    color: var(--white);
  }

  .event-info p {
    font-size: var(--text-sm);
    color: var(--patina);
    margin: 0;
    line-height: 1.6;
  }

  /* Photos */
  .photo-feature {
    margin-block: var(--space-xl);
    border-radius: 6px;
    overflow: hidden;
  }

  .photo-feature img {
    width: 100%;
    height: auto;
  }

  .photo-feature figcaption {
    font-size: var(--text-sm);
    color: var(--patina);
    font-style: italic;
    padding-top: var(--space-sm);
    text-align: center;
  }

  /* Map */
  .map-container {
    margin-top: var(--space-xl);
  }

  .map-address {
    margin-top: var(--space-md);
    font-size: var(--text-base);
  }

  /* CTA */
  .cta-section {
    padding-block: var(--space-4xl);
  }

  .cta-history-link {
    color: inherit;
    text-decoration-color: var(--live-oak);
    text-underline-offset: 3px;
  }

  .cta-history-link:hover {
    color: var(--live-oak);
  }

  .cta-actions {
    margin-top: var(--space-xl);
  }

  @media (max-width: 768px) {
    .hero-frame {
      padding: var(--space-2xl) var(--space-xl) var(--space-xl);
    }

    .hero-frame img {
      outline-width: 16px;
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.08),
        0 0 0 18px #e8e0d0,
        0 0 0 20px #3a3a3a,
        0 0 0 28px #1a1a1a,
        0 0 0 29px #333333,
        0 0 0 31px #111111,
        0 12px 36px rgba(0, 0, 0, 0.5);
    }

    .facts-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .hero-frame {
      padding: var(--space-xl) var(--space-md) var(--space-lg);
    }

    .hero-frame img {
      outline-width: 10px;
      box-shadow:
        inset 0 0 0 1px rgba(255, 255, 255, 0.08),
        0 0 0 12px #e8e0d0,
        0 0 0 13px #3a3a3a,
        0 0 0 19px #1a1a1a,
        0 0 0 20px #333333,
        0 0 0 21px #111111,
        0 8px 24px rgba(0, 0, 0, 0.5);
    }

    .facts-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-sm);
    }

    .event-card {
      flex-direction: column;
      gap: var(--space-md);
    }

    .event-date {
      width: 72px;
      height: 72px;
      flex-direction: column;
      gap: 0;
      min-width: unset;
    }
  }
</style>

<script>
  function countUp(el: HTMLElement, target: number, duration: number) {
    const start = target > 200 ? target - 60 : 0
    const range = target - start
    const startTime = performance.now()

    function tick(now: number) {
      const elapsed = now - startTime
      const progress = Math.min(elapsed / duration, 1)
      // Ease out cubic for gentle deceleration
      const eased = 1 - Math.pow(1 - progress, 3)
      const current = Math.round(start + range * eased)
      el.textContent = String(current)
      if (progress < 1) requestAnimationFrame(tick)
    }

    requestAnimationFrame(tick)
  }

  const counters = document.querySelectorAll<HTMLElement>('[data-count-to]')
  if (counters.length) {
    const counterObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting) {
            const el = entry.target as HTMLElement
            const target = parseInt(el.dataset.countTo || '0', 10)
            // Stagger based on position
            const delay = Array.from(counters).indexOf(el) * 150
            setTimeout(() => countUp(el, target, 2000), delay)
            counterObserver.unobserve(el)
          }
        })
      },
      { threshold: 0.5 }
    )
    counters.forEach((el) => counterObserver.observe(el))
  }

  // Typewriter effect
  const tw = document.querySelector<HTMLElement>('[data-typewriter]')
  if (tw) {
    const text = tw.dataset.typewriter || ''
    tw.textContent = ''
    let started = false

    const twObserver = new IntersectionObserver(
      (entries) => {
        entries.forEach((entry) => {
          if (entry.isIntersecting && !started) {
            started = true
            twObserver.unobserve(entry.target)
            // Delay after the slide-in animation completes
            setTimeout(() => {
              let i = 0
              const interval = setInterval(() => {
                tw.textContent = text.slice(0, i + 1)
                i++
                if (i >= text.length) clearInterval(interval)
              }, 55)
            }, 800)
          }
        })
      },
      { threshold: 0.3 }
    )
    twObserver.observe(tw)
  }
</script>
